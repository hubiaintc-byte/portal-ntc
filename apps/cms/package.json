{
  "name": "@ntc/cms",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    "./payload.config": "./src/payload.config.ts",
    "./shared/types": "./src/shared/types.ts"
  },
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "preview": "next start --port 3001",
    "start": "next start --port 3001",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "payload": "cross-env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload",
    "payload:generate": "pnpm payload generate:types",
    "payload:seed": "pnpm payload run src/seed/seed.ts",
    "payload:seed:imagens-home": "pnpm payload run src/seed/uploadImagensHome.ts",
    "payload:seed:home-v3": "pnpm payload run src/seed/seedHomeV3.ts",
    "payload:seed:edutec": "pnpm payload run src/seed/seedEventoEdutecM01.ts",
    "payload:seed:corpo-docente": "pnpm payload run src/seed/seedCorpoDocente.ts",
    "fotos:especialistas": "pnpm payload run src/seed/vincularFotosEspecialistas.ts",
    "clean": "rm -rf .next .turbo node_modules"
  },
  "dependencies": {
    "@ntc/lib": "workspace:*",
    "@ntc/types": "workspace:*",
    "@payloadcms/db-postgres": "3.18.0",
    "@payloadcms/next": "3.18.0",
    "@payloadcms/richtext-lexical": "3.18.0",
    "@payloadcms/storage-s3": "3.18.0",
    "@payloadcms/translations": "3.18.0",
    "cross-env": "^7.0.3",
    "graphql": "^16.10.0",
    "next": "15.5.18",
    "payload": "3.18.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "0.33.5",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.5.18",
    "typescript": "^5.7.2"
  }
}
