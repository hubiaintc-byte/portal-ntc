{
  "name": "portal-ntc",
  "version": "0.1.0",
  "private": true,
  "description": "Portal Grupo NTC — monorepo (Next.js + Payload CMS).",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "turbo run dev --filter=@ntc/web",
    "dev:cms": "turbo run dev --filter=@ntc/cms",
    "build": "turbo run build",
    "preview": "turbo run preview",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "payload:generate": "pnpm --filter @ntc/cms payload:generate",
    "payload:seed": "pnpm --filter @ntc/cms payload:seed",
    "payload:seed:imagens-home": "pnpm --filter @ntc/cms payload:seed:imagens-home",
    "payload:seed:home-v3": "pnpm --filter @ntc/cms payload:seed:home-v3",
    "payload:seed:edutec": "pnpm --filter @ntc/cms payload:seed:edutec",
    "payload:seed:folders": "pnpm --filter @ntc/cms payload:seed:folders",
    "fotos:especialistas": "pnpm --filter @ntc/cms fotos:especialistas",
    "revalidar": "node scripts/revalidar.mjs",
    "revalidar:corpo-docente": "node scripts/revalidar.mjs /o-grupo/corpo-docente",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
