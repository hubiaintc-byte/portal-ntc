# ==========================================================================
# Portal Grupo NTC — exemplo de variáveis de ambiente
# Copie para .env (nunca commit) e preencha conforme cada ambiente.
# Referência canônica: docs/10_DAB_Backend_Enxuto_GrupoNTC_v1.md §16.3
# e CLAUDE.md §15.
# ==========================================================================

# ---- Database (Neon Postgres · região São Paulo) -------------------------
DATABASE_URI=postgres://user:password@host:5432/ntc_dev

# ---- Payload CMS ---------------------------------------------------------
PAYLOAD_SECRET=troque-por-uma-string-aleatoria-de-no-minimo-32-bytes
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# ---- Front-end (apps/web) -----------------------------------------------
PAYLOAD_PUBLIC_FRONT_URL=http://localhost:3000
REVALIDATE_SECRET=troque-por-uma-string-aleatoria

# ---- Storage Cloudflare R2 ----------------------------------------------
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ntc-portal-media
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# ---- Integrações ---------------------------------------------------------
RDSTATION_TOKEN=
RESEND_API_KEY=
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=

# ---- Observabilidade -----------------------------------------------------
SENTRY_DSN=
