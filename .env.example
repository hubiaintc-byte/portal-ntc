# ==========================================================================
# Portal Grupo NTC — exemplo de variáveis de ambiente
# Copie para .env (nunca commit) e preencha conforme cada ambiente.
# Referência canônica: docs/10_DAB §3, §4 e CLAUDE.md §15.
# ==========================================================================

# ---- Database (Supabase Postgres · pooler porta 6543) -------------------
# Formato exato no painel: Dashboard → Connect → Transaction pooler.
# O prefixo numérico (aws-0, aws-1, ...) depende do cluster regional do projeto;
# copie a URI completa do painel para evitar erros.
DATABASE_URI=postgresql://postgres.<ref>:<senha>@aws-1-sa-east-1.pooler.supabase.com:6543/postgres

# ---- Supabase API --------------------------------------------------------
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Supabase Storage (S3-compat) ---------------------------------------
SUPABASE_S3_ENDPOINT=https://<ref>.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=sa-east-1
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
SUPABASE_BUCKET=ntc-portal-media

# ---- Payload CMS ---------------------------------------------------------
# Gerar com: openssl rand -base64 48 | tr -d '\n=' | tr '+/' '-_'
PAYLOAD_SECRET=
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# ---- Front-end (apps/web) -----------------------------------------------
PAYLOAD_PUBLIC_FRONT_URL=http://localhost:3000
REVALIDATE_SECRET=

# ---- E-mail transacional (Resend) ---------------------------------------
RESEND_API_KEY=

# ---- Captcha de formulários (hCaptcha) ----------------------------------
HCAPTCHA_SITE_KEY=
HCAPTCHA_SECRET=

# ---- Observabilidade -----------------------------------------------------
SENTRY_DSN=
